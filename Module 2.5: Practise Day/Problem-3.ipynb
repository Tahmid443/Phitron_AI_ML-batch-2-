   "source": [
    " Given a list [1,2,3,4], use map() and lambda to create a new list with squares of each number.\n",
    "\n",
    "Sample Input:\n",
    " No input\n",
    "\n",
    "Sample Output:\n",
    "[1, 4, 9, 16]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b82c10de",
   "metadata": {},
   "outputs": [],
   "source": [
    "ls = [1, 2, 3, 4]\n",
    "a = list(map(lambda x: x**2, ls))\n",
    "print(a)"
   ]
  }
