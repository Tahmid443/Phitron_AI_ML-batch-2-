   "source": [
    "Given a list [1,2,3,4,5,6], use filter() to select even numbers and map() with lambda to\n",
    "square them.\n",
    "Sample Input:\n",
    "No input\n",
    "Sample Output:\n",
    "[4, 16, 36]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "37f89b1f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[4, 16, 36]\n"
     ]
    }
   ],
   "source": [
    "ls = [1,2,3,4,5,6]\n",
    "result = list(map(lambda x:x**2, filter(lambda x:x%2==0, ls)))\n",
    "print(result)"
   ]
  }
 ],
