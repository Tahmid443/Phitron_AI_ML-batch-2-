   "source": [
    " Given a list [1,2,3,4], use map() and lambda to create a new list with squares of each number.\n",
    "\n",
    "Sample Input:\n",
    " No input\n",
    "\n",
    "Sample Output:\n",
    "[1, 4, 9, 16]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "b82c10de",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1, 4, 9, 16]\n"
     ]
    }
   ],
   "source": [
    "ls = [1, 2, 3, 4]\n",
    "a = list(map(lambda x: x**2, ls))\n",
    "print(a)"
   ]
  }
